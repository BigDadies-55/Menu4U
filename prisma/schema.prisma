generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OWNER
  EDITOR
  VIEWER
  WAITER
  DISPLAY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
  PAID
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?
  lastActivityAt     DateTime?

  termsAccepted          Boolean   @default(false)
  termsAcceptedAt        DateTime?
  termsAcceptedIp        String?
  termsAcceptedUserAgent String?

  accounts        Account[]
  sessions        Session[]
  restaurantUsers RestaurantUser[]
}

model PasswordPolicy {
  id                  String   @id @default("default")
  maxAgeDays          Int      @default(0)
  minLength           Int      @default(8)
  requireUppercase    Boolean  @default(false)
  requireNumbers      Boolean  @default(false)
  requireSymbols      Boolean  @default(false)
  idleTimeoutMinutes  Int      @default(0)
  updatedAt           DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RestaurantGroup {
  id          String       @id @default(cuid())
  name        String
  logo        String?
  createdAt   DateTime     @default(now())

  restaurants Restaurant[]
  loyaltyMembers LoyaltyMember[]
}

model Restaurant {
  id            String   @id @default(cuid())
  name          String
  description   String?
  logo          String?
  address       String?
  phone         String?
  phone2        String?
  orderPhone    String?
  email         String?
  website       String?
  locationUrl   String?
  isActive      Boolean  @default(true)
  menuTheme     String   @default("elegant")
  menuPalette     String   @default("0")
  menuPaletteData String?
  ordersEnabled   Boolean @default(false)
  tableLayoutJson String?
  kdsView       String   @default("STATION_DARK")
  customDomain  String?
  copyright     String?
  language      String    @default("he")
  welcomeText   String?
  splashImage   String?
  subscriptionFrom DateTime?
  subscriptionTo   DateTime?
  // Social links
  instagram     String?
  facebook      String?
  whatsapp      String?
  tripadvisor   String?
  googleReview  String?
  // Public visibility
  showPhonePublic   Boolean @default(true)
  showAddressPublic Boolean @default(true)
  // Chain/group membership
  groupId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group           RestaurantGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  restaurantUsers RestaurantUser[]
  menus           Menu[]
  orders          Order[]
  menuViews       MenuView[]
  tableSessions   TableSession[]
  customers       Customer[]
  orderCounter    OrderCounter?
  loyaltyMembers  LoyaltyMember[]
  loyaltySettings LoyaltySettings?
}

model RestaurantUser {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
}

model Menu {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  isActive     Boolean  @default(true)
  isPrimary    Boolean  @default(false)
  scheduleDays String[] @default([])
  scheduleFrom String?
  scheduleTo   String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories Category[]
}

model Category {
  id           String   @id @default(cuid())
  menuId       String
  name         String
  description  String?
  image        String?
  isActive     Boolean  @default(true)
  autoReady    Boolean  @default(false)
  sortOrder    Int      @default(0)
  translations Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  menu  Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items Item[]
}

model Item {
  id           String  @id @default(cuid())
  categoryId   String
  name         String
  description  String?
  price        Float
  image        String?
  isActive     Boolean @default(true)
  isVegetarian Boolean  @default(false)
  isVegan      Boolean  @default(false)
  isGlutenFree Boolean  @default(false)
  tags         String[]
  prepTime     Int?
  sortOrder    Int      @default(0)
  translations Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category        Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  modifierGroups  ItemModifierGroup[]
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String
  tableNumber   String?
  customerName  String?
  customerPhone String?
  status        OrderStatus @default(PENDING)
  orderNumber   Int?
  totalAmount   Float
  notes         String?
  coversCount   Int?                              // כמות סועדים בשולחן
  orderSource   String      @default("CUSTOMER") // CUSTOMER | WAITER | PHONE
  // Loyalty redemption — locked to first member who redeems
  loyaltyMemberId      String?
  loyaltyMemberName    String?
  loyaltyDiscountType  String?  // POINTS | COUPON
  loyaltyDiscountAmount Float?
  loyaltyCouponId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restaurant  Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  statusLogs  OrderStatusLog[]
}

model OrderCounter {
  restaurantId String @id
  counter      Int    @default(0)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model OrderStatusLog {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String
  toStatus   String
  changedAt  DateTime @default(now())
  changedBy  String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  itemId          String
  quantity        Int
  price           Float
  notes           String?
  itemStatus      String    @default("PENDING")
  course          Int       @default(1)     // 1=ראשון, 2=עיקרי, 3=קינוח
  heldUntilFired  Boolean   @default(false) // true = ממתין ל-fire לפני שיורד למטבח
  firedAt         DateTime?                 // מתי הפריט "הוצת" למטבח
  doneAt          DateTime?                 // מתי הפריט הושלם
  servedAt        DateTime?                 // מתי המנה הוגשה לשולחן בפועל

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item      Item                @relation(fields: [itemId], references: [id])
  modifiers OrderItemModifier[]
}

model ItemModifierGroup {
  id        String         @id @default(cuid())
  itemId    String
  name      String
  required  Boolean        @default(false)
  maxSelect Int            @default(1)
  order     Int            @default(0)

  item      Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options   ItemModifier[]
}

model ItemModifier {
  id       String             @id @default(cuid())
  groupId  String
  label    String
  priceAdd Float              @default(0)
  order    Int                @default(0)

  group    ItemModifierGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  groupName   String
  label       String
  priceAdd    Float     @default(0)

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model MenuView {
  id           String   @id @default(cuid())
  restaurantId String
  type         String
  refId        String?
  refName      String?
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  entity     String?
  entityId   String?
  entityName String?
  meta       Json?
  ip         String?
  createdAt  DateTime @default(now())
}

model TableSession {
  id           String   @id @default(cuid())
  restaurantId String
  tableNumber  String
  openedAt     DateTime
  closedAt     DateTime @default(now())
  totalAmount  Float    @default(0)
  orderCount   Int      @default(0)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model SiteConfig {
  id           String   @id @default("default")
  siteName     String   @default("Menu4U")
  logo         String?
  domain       String?
  copyright    String?
  adminPalette String   @default("dark")
  updatedAt    DateTime @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  phone        String?
  email        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model LoyaltyMember {
  id           String   @id @default(cuid())
  restaurantId String
  groupId      String?
  phone        String
  name         String
  email        String?
  birthDate    DateTime?
  memberNumber String
  points       Int      @default(0)
  totalSpent   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  group        RestaurantGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  transactions LoyaltyTransaction[]
  coupons      LoyaltyCoupon[]

  @@unique([restaurantId, phone])
  @@unique([restaurantId, memberNumber])
}

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  memberId  String
  orderId   String?
  type      String   // EARN | REDEEM | BONUS | MANUAL
  points    Int
  note      String?
  createdAt DateTime @default(now())

  member    LoyaltyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model LoyaltyCoupon {
  id                String    @id @default(cuid())
  memberId          String
  restaurantId      String
  validForGroupId   String?
  usedAtRestaurantId String?
  code              String    @unique
  type              String    // DISCOUNT_PERCENT | DISCOUNT_AMOUNT | FREE_ITEM
  value             Float
  description       String?
  usedAt            DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())

  member       LoyaltyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model LoyaltySettings {
  restaurantId    String @id
  pointsPerShekel Float  @default(1)
  shekelPerPoint  Float  @default(0.1)
  minRedeemPoints Int    @default(100)
  welcomeBonus    Int    @default(50)
  birthdayBonus   Int    @default(100)
  isActive        Boolean @default(true)

  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}
