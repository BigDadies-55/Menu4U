# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────
# REQUIRED — generate strong random value: openssl rand -base64 32
# WARNING: never use a guessable value — a weak secret allows JWT token forgery
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://yourdomain.com"
AUTH_URL="https://yourdomain.com"

# ─── App URL (used by cron, SSE, emails) ────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── Email — Gmail SMTP ──────────────────────────────────────
# Use App Password (not your regular Gmail password)
# https://myaccount.google.com/apppasswords
GMAIL_USER="your@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── SMS — Inforu ────────────────────────────────────────────
# https://www.inforu.co.il
INFORU_USERNAME="your_username"
INFORU_API_TOKEN="your_token"
INFORU_SENDER_NAME="Menu4U"

# ─── Images — Cloudinary ─────────────────────────────────────
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── AI — Anthropic (allergen auto-fill) ─────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Cron (GitHub Actions) ───────────────────────────────────
# Generate: openssl rand -base64 32
# Must match GitHub Secret: CRON_SECRET
CRON_SECRET="your-cron-secret"

# ─── Setup endpoint (one-time DB setup) ──────────────────────
SETUP_SECRET="your-setup-secret"
